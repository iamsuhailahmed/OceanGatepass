<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="40dp">

    <!-- Logo Icon -->
    <ImageView
        android:id="@+id/splash_logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_logo"
        android:alpha="0"
        android:contentDescription="Ocean Gatepass Logo" />

    <!-- App Name -->
    <TextView
        android:id="@+id/splash_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Ocean Gatepass"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:alpha="0"
        android:letterSpacing="0.05" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/splash_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Secure • Fast • Reliable"
        android:textColor="#B0C4DE"
        android:textSize="14sp"
        android:alpha="0"
        android:letterSpacing="0.1" />

    <!-- Divider -->
    <View
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:layout_marginTop="24dp"
        android:background="#4FC3F7"
        android:alpha="0.7" />

    <!-- Company name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Ocean Fibers"
        android:textColor="#90A4AE"
        android:textSize="12sp"
        android:letterSpacing="0.15" />

    <!-- Progress indicator -->
    <ProgressBar
        android:id="@+id/splash_progress"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="160dp"
        android:layout_height="3dp"
        android:layout_marginTop="60dp"
        android:indeterminate="true"
        android:progressTint="#4FC3F7"
        android:alpha="0" />

</LinearLayout>
