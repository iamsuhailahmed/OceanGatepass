<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <!-- WebView - full screen -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible" />

    <!-- Loading screen -->
    <LinearLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/splash_background"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_logo"
            android:contentDescription="Loading" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Ocean Gatepass"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ProgressBar
            android:layout_width="120dp"
            android:layout_height="3dp"
            android:layout_marginTop="30dp"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:indeterminate="true"
            android:progressTint="#4FC3F7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="لوڈ ہو رہا ہے..."
            android:textColor="#90A4AE"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Error screen -->
    <LinearLayout
        android:id="@+id/errorLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/splash_background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="gone">

        <!-- Error icon -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_error"
            android:contentDescription="Error" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="کنیکشن میں خرابی"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/errorMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="سرور سے رابطہ نہیں ہوسکا"
            android:textColor="#90A4AE"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:layout_marginTop="30dp"
            android:text="دوبارہ کوشش کریں"
            android:textSize="14sp"
            android:background="@drawable/btn_retry"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</FrameLayout>
